# Anthropic API Key (Zorunlu)
ANTHROPIC_API_KEY=sk-ant-...

# Gerçek LinkedIn Scraping (true/false)
# true = Gerçek LinkedIn verisi (Playwright ile)
# false = Mock/Demo verisi (varsayılan)
USE_REAL_SCRAPING=false

# LinkedIn Cookie (Opsiyonel - otomatik giriş için)
LINKEDIN_COOKIE=...

# Output dizini (Default: ./reports)
OUTPUT_DIR=./reports

# Günlük profil limiti
MAX_PROFILES_PER_DAY=50

# Profiller arası bekleme süresi (ms)
DELAY_MIN_MS=3000
DELAY_MAX_MS=7000
